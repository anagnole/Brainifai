# GraphStore backend: kuzu (default, embedded) or neo4j
GRAPHSTORE_BACKEND=kuzu

# Kuzu (embedded graph DB, no server needed)
KUZU_DB_PATH=./data/kuzu

# Neo4j (only needed if GRAPHSTORE_BACKEND=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL_IDS=C01ABCDEF,C02GHIJKL

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPOS=owner/repo,owner/repo2

# Ingestion
BACKFILL_DAYS=7

# Topic extraction
TOPIC_ALLOWLIST=deploy,release,incident,outage,migration,security,performance,testing

# ClickUp
CLICKUP_TOKEN=pk_xxxxxxxxxxxx
CLICKUP_LIST_IDS=abc123,def456

# Apple Calendar (CalDAV via iCloud)
# Generate an app-specific password at: https://appleid.apple.com → Security → App-Specific Passwords
APPLE_CALDAV_USERNAME=your@apple.id
APPLE_CALDAV_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Optional: comma-separated calendar names to include (empty = all calendars)
APPLE_CALDAV_CALENDARS=

# fal.ai (image generation MCP server)
FAL_KEY=your-fal-api-key
