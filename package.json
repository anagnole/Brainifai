{
  "name": "brainifai",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test-connection": "tsx --env-file=.env src/scripts/test-connection.ts",
    "schema": "tsx --env-file=.env src/scripts/seed-schema.ts",
    "ingest": "tsx --env-file=.env src/ingestion/index.ts",
    "mcp": "tsx --env-file=.env src/mcp/index.ts",
    "mcp-fal": "tsx --env-file=.env src/mcp-fal/index.ts",
    "mcp-clickup": "tsx --env-file=.env src/mcp-clickup/index.ts",
    "mcp-figma": "npm --prefix ../figma-writer-mcp start",
    "ui": "npm --prefix ui run dev",
    "launch": "bash scripts/launchagent.sh install",
    "launch:stop": "bash scripts/launchagent.sh uninstall",
    "launch:status": "bash scripts/launchagent.sh status",
    "launch:logs": "tail -f logs/brainifai.log"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.3",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.14.0",
    "neo4j-driver": "^5.27.0",
    "pino": "^9.6.0",
    "tsdav": "^2.1.8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
