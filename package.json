{
  "name": "brainifai",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "brainifai": "./bin/brainifai.js"
  },
  "scripts": {
    "cli": "LOG_LEVEL=silent tsx --env-file=.env src/cli/index.ts",
    "test-connection": "tsx --env-file=.env src/scripts/test-connection.ts",
    "schema": "tsx --env-file=.env src/scripts/seed-schema.ts",
    "ingest": "tsx --env-file=.env src/ingestion/index.ts",
    "mcp": "tsx --env-file=.env src/mcp/index.ts",
    "launch": "bash scripts/launchagent.sh install",
    "launch:stop": "bash scripts/launchagent.sh uninstall",
    "launch:status": "bash scripts/launchagent.sh status",
    "launch:logs": "tail -f logs/brainifai.log",
    "test": "vitest run",
    "smoke": "tsx src/scripts/smoke-test.ts",
    "viz:dev": "npx concurrently \"tsx --env-file=.env src/api/server.ts\" \"npx vite --config src/viz/vite.config.ts\"",
    "viz:build": "npx vite build --config src/viz/vite.config.ts",
    "viz": "npm run viz:build && tsx --env-file=.env src/api/server.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.14.0",
    "commander": "^14.0.3",
    "fastify": "^5.7.4",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "graphology-types": "^0.24.8",
    "kuzu": "^0.11.3",
    "pino": "^9.6.0",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sigma": "^3.0.2",
    "tsdav": "^2.1.8",
    "ulid": "^3.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
